# CharacterForge AI - Environment Configuration

# ==================== API Configuration ====================
# Groq API
GROQ_API_KEY=your_groq_api_key_here

# JWT Secret (change in production!)
SECRET_KEY=your-super-secret-key-change-in-production

# ==================== Database Configuration ====================
# Local SQLite (default)
# DATABASE_URL=sqlite:///characters.db

# PostgreSQL (Production)
DATABASE_URL=postgresql://user:password@localhost:5432/characterforge

# ==================== Redis Configuration ====================
# Redis for caching
REDIS_URL=redis://localhost:6379/0

# ==================== Environment ====================
ENVIRONMENT=development
DEBUG=True

# ==================== AWS Configuration ====================
# AWS S3 for asset storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=characterforge-assets

# ==================== Frontend Configuration ====================
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ==================== Email Configuration ====================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ==================== Feature Flags ====================
ENABLE_IMAGE_GENERATION=True
ENABLE_LORA_TRAINING=False
ENABLE_RAG_SYSTEM=True
ENABLE_ANALYTICS=True
ENABLE_ADMIN_PANEL=True

# ==================== Model Configuration ====================
# Groq Model
GROQ_MODEL=llama-3.3-70b-versatile

# Image Generation
IMAGE_GENERATION_MODEL=stabilityai/sdxl-turbo
ENABLE_FACE_RESTORATION=True
ENABLE_UPSCALING=True

# ==================== Performance ====================
MAX_WORKERS=4
CACHE_TTL_SECONDS=3600
RATE_LIMIT_PER_MINUTE=60

# ==================== Logging ====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
